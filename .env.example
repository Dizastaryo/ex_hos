# Канонический шаблон конфига. Скопируй в .env.local и заполни.
# Для других окружений: .env.staging, .env.production. Они в .gitignore.
# Выбор файла — через переменную APP_ENV (local|staging|production), default = local.

APP_ENV=local
APP_PORT=8001

# Подключение к Postgres
DATABASE_URL=postgres://user:password@localhost:5432/seeu?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=300

# JWT-секреты. На любом окружении кроме local — минимум 32 символа,
# должны различаться. Generate: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXP_HOURS=24
JWT_REFRESH_EXP_DAYS=30

# Опционально. Без ключа AI-ручки вернут 503.
OPENAI_API_KEY=

# WhatsApp bridge (отдельный Node-сервис `whatps`) для доставки OTP.
# Пусто ⇒ dev-mode: код логируется, принимается "0000".
WHATSAPP_SERVICE_URL=

# OTP конфигурация. По умолчанию: TTL=5 мин, 5 попыток на код, 3 send'а в час на номер.
OTP_CODE_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_MAX_PER_HOUR=3

# CORS whitelist (comma-separated origins). Пусто → allow-all (DEV ONLY).
# Прод обязательно: https://seeu.kz,https://admin.seeu.kz,https://api.seeu.kz
CORS_ALLOWED_ORIGINS=

# rembg_server.py (порт 8004) — модель удаления фона для стикеров.
# local/dev  → birefnet-general-lite  (быстрая, ~60 MB, работает на слабом CPU)
# production → birefnet-portrait      (лучшее качество, ~400 MB, нужен GPU)
REMBG_MODEL=birefnet-general-lite

# Cloudflare R2 (общее облако для файлов). Без этих переменных — локальный диск.
# Endpoint: https://<account_id>.r2.cloudflarestorage.com
# PublicURL: включи Public Access на bucket → скопируй URL вида https://pub-xxx.r2.dev
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=seeu-uploads
R2_PUBLIC_URL=
